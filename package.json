{
  "name": "lilmonkeycatluvmusic",
  "version": "0.0.0",
  "private": true,
  "description": "猴猫直播模拟器 — 纯前端离线单页文字养成游戏",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@preact/preset-vite": "^2.10.1",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  }
}
